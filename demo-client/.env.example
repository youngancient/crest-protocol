# ==========================================
# Crest Protocol Demo Client - Environment Variables
# ==========================================

# 1. WalletConnect / Reown AppKit Project ID (Required for wallet connection Modal)
# Get yours for free at https://cloud.reown.com
VITE_APPKIT_PROJECT_ID=your_reown_project_id_here

# 2. Rootstock RPC Provider (Required for Read-Only mode when wallet is disconnected)
# E.g. https://public-node.testnet.rsk.co
VITE_ROOTSTOCK_TESTNET_RPC_URL=https://public-node.testnet.rsk.co

# 3. Crest Protocol Smart Contracts (The proxy instances you deployed via Hardhat)
VITE_CREST_CORE_ADDRESS=
VITE_CREST_EVENTS_ADDRESS=

# 4. Rootstock Attestation Service (RAS) Proxy Address
# Testnet: 0xc300aeEadd60999933468738c9F5d7e9c0671e1C
VITE_EAS_ADDRESS=0xc300aeEadd60999933468738c9F5d7e9c0671e1C